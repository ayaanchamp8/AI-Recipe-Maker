{
  "entities": {
    "SearchEvent": {
      "title": "Search Event",
      "description": "An event indicating a recipe search.",
      "type": "object",
      "properties": {
        "dish": { "type": "string" },
        "vegetarian": { "type": "boolean" },
        "allergies": { "type": "string" },
        "cuisine": { "type": "string" },
        "difficulty": { "type": "string" },
        "outcome": { "type": "string", "enum": ["success", "error"] },
        "ip_address": { "type": "string" },
        "country": { "type": "string" },
        "visitor_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["dish", "outcome", "created_at"]
    },
    "PageView": {
      "title": "Page View",
      "description": "An event indicating a page view.",
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["path", "created_at"]
    },
    "SavedRecipe": {
      "title": "Saved Recipe",
      "description": "A recipe bookmarked by a user.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "recipe": { "type": "object" },
        "savedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "recipe", "savedAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "Feedback submitted on generated recipes.",
      "type": "object",
      "properties": {
        "recipeName": { "type": "string" },
        "userName": { "type": "string" },
        "comment": { "type": "string" },
        "rating": { "type": "integer" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["recipeName", "userName", "rating", "created_at"]
    }
  },
  "firestore": {
    "searchEvents": {
      "schema": { "$ref": "#/entities/SearchEvent" },
      "description": "Stores recipe search events."
    },
    "pageViews": {
      "schema": { "$ref": "#/entities/PageView" },
      "description": "Stores website page views."
    },
    "feedbacks": {
      "schema": { "$ref": "#/entities/Feedback" },
      "description": "Stores user recipe feedback events."
    },
    "users/{userId}/savedRecipes/{recipeId}": {
      "schema": { "$ref": "#/entities/SavedRecipe" },
      "description": "A user's saved recipes."
    }
  }
}
